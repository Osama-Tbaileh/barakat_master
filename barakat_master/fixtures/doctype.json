        "in_list_view": 1,
        "in_standard_filter": 1
      },
      {
        "fieldname": "site_url",
        "fieldtype": "Data",
        "label": "Site URL",
        "reqd": 1,
        "in_list_view": 1,
        "in_standard_filter": 1
      },
      {
        "fieldname": "company_name",
        "fieldtype": "Data",
        "label": "Company Name",
        "in_list_view": 1
      },
      {
        "fieldname": "is_active",
        "fieldtype": "Check",
        "label": "Is Active",
        "default": "1",
        "in_list_view": 1
      }
    ],
    "allow_auto_repeat": 0
  }
]
