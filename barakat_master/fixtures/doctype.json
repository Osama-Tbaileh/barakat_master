[
  {
    "doctype": "DocType",
    "name": "User Site Mapping",
    "module": "Barakat Master",
    "custom": 1,
    "istable": 0,
    "track_changes": 1,
    "autoname": "autoname",
    "field_order": ["user", "site_url", "company_name", "is_active"],
